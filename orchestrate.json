    "codex": {
      "command": "codex exec",
      "flags": "--json -s read-only"
    },
    "gemini": {
      "command": "gemini",
      "flags": "-o json --approval-mode auto_edit"
    },
    "phases": {
      "discover": ["codex"],
      "define": ["codex", "gemini"],
      "develop": [],
